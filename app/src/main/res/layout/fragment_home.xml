<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimaryContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Welcome -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, User"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="70dp"
            android:layout_marginBottom="18dp" />

        <!-- Pins section (hidden when empty) -->
        <TextView
            android:id="@+id/tvAnnouncementsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pins"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAnnouncements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

        <!-- Quick Access label -->
        <TextView
            android:id="@+id/tvQuickAccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Access"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp" />

        <!-- Quick Access grid card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:columnCount="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileEvents"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_events" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Events" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileChats"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_chat" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Chats" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileQr"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_qr" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="QR Code" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileCalendar"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_calendar" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Calendar" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tilePolls"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_polls" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Polls" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileGallery"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_gallery" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Gallery" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Admin Items label (hidden for non-admins) -->
        <TextView
            android:id="@+id/tvAdminItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Items"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <!-- Admin Items grid card (hidden for non-admins) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAdminDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            android:visibility="gone">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:columnCount="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileUserManagement"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_person" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="User" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Management" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileCreatePoll"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_check" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Create" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Poll" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileCreateEvent"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_events" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Create" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Event" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileCreatePin"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_clip" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Create" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pin" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileEditSociety"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_margin="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSecondaryContainer"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_edit" app:tint="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Edit" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Society" android:textStyle="bold" android:textColor="?attr/colorOnSecondaryContainer"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_margin="10dp"
                    android:layout_columnWeight="1" />

            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
