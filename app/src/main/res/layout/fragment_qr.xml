<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/tvQrTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="QR Scanner"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1E1E1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvQrSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Scan a society or event invite. Once detected, the app will open the correct destination automatically."
        android:textSize="14sp"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/tvQrTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Camera preview card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCameraPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#1B1B1B"
        app:layout_constraintTop_toBottomOf="@id/tvQrSubtitle"
        app:layout_constraintBottom_toTopOf="@id/tvQrInstruction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="H,1:1.1">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Live camera preview — fills the card -->
            <com.journeyapps.barcodescanner.BarcodeView
                android:id="@+id/barcodeView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Scanner frame -->
            <FrameLayout
                android:id="@+id/frameScanner"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="34dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_qr_scanner_outline" />

                <View
                    android:id="@+id/viewScanLine"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_gravity="top"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="48dp"
                    android:layout_marginEnd="18dp"
                    android:background="@color/button1" />

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_qr"
                    app:tint="#55FFFFFF" />
            </FrameLayout>

            <!-- top-left corner -->
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="34dp"
                android:layout_marginTop="34dp"
                android:background="@drawable/bg_qr_corner_tl"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- top-right corner -->
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="34dp"
                android:layout_marginTop="34dp"
                android:background="@drawable/bg_qr_corner_tr"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- bottom-left corner -->
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="34dp"
                android:layout_marginBottom="34dp"
                android:background="@drawable/bg_qr_corner_bl"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- bottom-right corner -->
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="34dp"
                android:layout_marginBottom="34dp"
                android:background="@drawable/bg_qr_corner_br"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvQrInstruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Hold the QR code inside the frame. The app will automatically continue when a valid SocietyHive QR is detected."
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/cardCameraPreview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvQrFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Future flows: society invite, event invite, attendance check-in."
        android:textColor="#8A8A8A"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvQrInstruction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
