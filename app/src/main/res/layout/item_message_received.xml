<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:paddingStart="4dp"
    android:paddingEnd="60dp"
    android:gravity="bottom">

    <!-- Sender avatar -->
    <ImageView
        android:id="@+id/ivSenderAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_profile"
        android:background="@drawable/bg_circle_neutral"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:contentDescription="Sender avatar" />

    <!-- Bubble + name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMessageSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="2dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#88000000"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F8E7EA">

            <TextView
                android:id="@+id/tvMessageReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textColor="#1E1E1E"
                android:textSize="15sp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
