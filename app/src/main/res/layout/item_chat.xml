<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#F7E0E4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/viewAccent"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/button1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_profile"
                app:tint="#6C5D61" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvChatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Motorsport Society"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#1E1E1E" />

                <TextView
                    android:id="@+id/tvChatPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="You: Last night was crazy!"
                    android:textSize="13sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvChatTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18:42"
                android:textSize="12sp"
                android:textColor="#666666" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
