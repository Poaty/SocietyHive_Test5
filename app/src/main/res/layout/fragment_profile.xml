<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimaryContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Profile picture -->
        <ImageView
            android:id="@+id/ivProfilePicture"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_profile"
            android:background="@drawable/bg_profile_role_chip"
            android:padding="12dp"
            android:scaleType="centerCrop"
            app:tint="?attr/colorPrimary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Profile picture" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tap to change photo"
            android:textSize="11sp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:alpha="0.7" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="SocietyHive Member"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimaryContainer" />

        <!-- Email -->
        <TextView
            android:id="@+id/tvProfileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="member@email.com"
            android:textSize="13sp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:alpha="0.7" />

        <!-- Role -->
        <TextView
            android:id="@+id/tvProfileRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Member"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:background="?attr/colorPrimary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.2" />

        <!-- My Societies header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Societies"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimaryContainer" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvJoinedSocieties"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.2" />

        <!-- Log out button -->
        <Button
            android:id="@+id/btnLogOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log Out"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary" />

    </LinearLayout>
</ScrollView>
