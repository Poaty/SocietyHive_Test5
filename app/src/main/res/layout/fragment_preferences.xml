<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimaryContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Section header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSecondaryContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Colour Scheme"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="Choose the accent colour used across the app."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- Colour swatches grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Crimson -->
                    <LinearLayout
                        android:id="@+id/swatchCrimson"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:id="@+id/circCrimson"
                            android:layout_width="48dp"
                            android:layout_height="48dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Crimson"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface"/>

                        <ImageView
                            android:id="@+id/tickCrimson"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="visible"
                            app:tint="?attr/colorPrimary"/>
                    </LinearLayout>

                    <!-- Midnight Blue -->
                    <LinearLayout
                        android:id="@+id/swatchBlue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:id="@+id/circBlue"
                            android:layout_width="48dp"
                            android:layout_height="48dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Midnight"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface"/>

                        <ImageView
                            android:id="@+id/tickBlue"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="?attr/colorPrimary"/>
                    </LinearLayout>

                    <!-- Forest Green -->
                    <LinearLayout
                        android:id="@+id/swatchGreen"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:id="@+id/circGreen"
                            android:layout_width="48dp"
                            android:layout_height="48dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Forest"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface"/>

                        <ImageView
                            android:id="@+id/tickGreen"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="?attr/colorPrimary"/>
                    </LinearLayout>

                    <!-- Slate Purple -->
                    <LinearLayout
                        android:id="@+id/swatchPurple"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:id="@+id/circPurple"
                            android:layout_width="48dp"
                            android:layout_height="48dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Slate"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface"/>

                        <ImageView
                            android:id="@+id/tickPurple"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="?attr/colorPrimary"/>
                    </LinearLayout>

                    <!-- Charcoal -->
                    <LinearLayout
                        android:id="@+id/swatchCharcoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:id="@+id/circCharcoal"
                            android:layout_width="48dp"
                            android:layout_height="48dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Charcoal"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface"/>

                        <ImageView
                            android:id="@+id/tickCharcoal"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="?attr/colorPrimary"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Selected scheme label -->
                <TextView
                    android:id="@+id/tvSelectedScheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_gravity="center_horizontal"
                    android:text="Selected: Crimson"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Display section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:letterSpacing="0.1"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSecondaryContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Compact events -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_events"
                        app:tint="?attr/colorPrimary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compact Event Cards"
                            android:textSize="15sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show less detail in the events list"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCompactEvents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
