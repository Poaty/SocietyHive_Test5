<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Section header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#AAFFFFFF"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F7E0E4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Colour Scheme"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E1E1E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="Choose the accent colour used across the app."
                    android:textSize="13sp"
                    android:textColor="#666666"/>

                <!-- Colour swatches grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Crimson (default) -->
                    <LinearLayout
                        android:id="@+id/swatchCrimson"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#8D2E3A"
                            android:id="@+id/circCrimson"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Crimson"
                            android:textSize="11sp"
                            android:textColor="#1E1E1E"/>

                        <ImageView
                            android:id="@+id/tickCrimson"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="visible"
                            app:tint="@color/button1"/>
                    </LinearLayout>

                    <!-- Midnight Blue -->
                    <LinearLayout
                        android:id="@+id/swatchBlue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#1A3A6B"
                            android:id="@+id/circBlue"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Midnight"
                            android:textSize="11sp"
                            android:textColor="#1E1E1E"/>

                        <ImageView
                            android:id="@+id/tickBlue"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="#1A3A6B"/>
                    </LinearLayout>

                    <!-- Forest Green -->
                    <LinearLayout
                        android:id="@+id/swatchGreen"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#1E5C2E"
                            android:id="@+id/circGreen"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Forest"
                            android:textSize="11sp"
                            android:textColor="#1E1E1E"/>

                        <ImageView
                            android:id="@+id/tickGreen"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="#1E5C2E"/>
                    </LinearLayout>

                    <!-- Slate Purple -->
                    <LinearLayout
                        android:id="@+id/swatchPurple"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#4A2372"
                            android:id="@+id/circPurple"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Slate"
                            android:textSize="11sp"
                            android:textColor="#1E1E1E"/>

                        <ImageView
                            android:id="@+id/tickPurple"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="#4A2372"/>
                    </LinearLayout>

                    <!-- Charcoal -->
                    <LinearLayout
                        android:id="@+id/swatchCharcoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#2E2E2E"
                            android:id="@+id/circCharcoal"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Charcoal"
                            android:textSize="11sp"
                            android:textColor="#1E1E1E"/>

                        <ImageView
                            android:id="@+id/tickCharcoal"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_search"
                            android:visibility="invisible"
                            app:tint="#2E2E2E"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Selected scheme preview label -->
                <TextView
                    android:id="@+id/tvSelectedScheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_gravity="center_horizontal"
                    android:text="Selected: Crimson"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Note: colour scheme changes take effect the next time you restart the app."
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Display section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#AAFFFFFF"
            android:letterSpacing="0.1"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F7E0E4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Compact events -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_events"
                        app:tint="@color/button1"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compact Event Cards"
                            android:textSize="15sp"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show less detail in the events list"
                            android:textSize="12sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCompactEvents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
